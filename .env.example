# MUSIC_PROVIDER: mock | elevenlabs (sound effects, /v1/sound-generation) | elevenmusic (Eleven Music, /v1/music)
# 'elevenmusic' requires the API key to have Music Generation = Access enabled.
ANALYSIS_PROVIDER=mock
MUSIC_PROVIDER=mock
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
STEM_PROVIDER=mock
DEMUCS_PYTHON_CMD=python
REPLICATE_API_KEY=
REPLICATE_MODEL_VERSION=

# Clerk auth (Phase B). Create an app at https://dashboard.clerk.com and paste the keys.
# Leave blank to run without auth — the app builds/runs and the auth UI stays hidden.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Where to land after auth (Projects page exists as of Phase D).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/projects
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/projects

# Database (Phase C) — Neon Postgres connection string (pooled). https://neon.tech
DATABASE_URL=

# File storage (Phase C): vercel-blob (default) | local (dev fallback, serves from public/projects)
STORAGE_PROVIDER=vercel-blob
# Required when STORAGE_PROVIDER=vercel-blob. Create a Blob store at vercel.com → Storage.
BLOB_READ_WRITE_TOKEN=
