# MUSIC_PROVIDER: mock | elevenmusic (default when key set) | sound-generation (legacy 22s cap)
# When ELEVENLABS_API_KEY is set, 'elevenlabs' and unset both route to the Music API (full clip length).
# Set MUSIC_PROVIDER=sound-generation to force the legacy /v1/sound-generation endpoint (max 22s).
# Music API requires the key to have "Music Generation = Access" enabled in the ElevenLabs dashboard.
ANALYSIS_PROVIDER=mock
MUSIC_PROVIDER=mock
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
STEM_PROVIDER=mock
DEMUCS_PYTHON_CMD=python
REPLICATE_API_KEY=
REPLICATE_MODEL_VERSION=
